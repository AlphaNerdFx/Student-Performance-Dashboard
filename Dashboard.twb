          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1mknmvp0t4fqqr10t9zp519xrzyg'>
            <column aggregation='Sum' caption='Attendance Lifestyle' datatype='integer' name='[Attendance (copy)_1205838847915532306]' role='dimension' type='ordinal'>
