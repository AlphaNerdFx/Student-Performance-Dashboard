              <calculation class='tableau' formula='CASE [Parameters].[Parameter 4]&#13;&#10;WHEN &apos;Family Income&apos; THEN [Family_Income]&#13;&#10;WHEN &apos;Parental Education Level&apos; THEN [Parental_Education_Level]&#13;&#10;WHEN &apos;Parental Involvement&apos; THEN [Parental_Involvement]&#13;&#10;END' />
