            <column caption='DimensionSlider' datatype='string' name='[Calculation_1205838847671795714]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &apos;Distance from Home&apos; THEN STR([Distance_from_Home])&#13;&#10;WHEN &apos;Extracurricular Activities&apos; THEN [Extracurricular_Activities]&#13;&#10;WHEN &apos;Family Income&apos; THEN STR([Family_Income])&#13;&#10;WHEN &apos;Gender&apos; THEN [Gender]&#13;&#10;WHEN &apos;Internet Access&apos; THEN STR([Internet_Access])&#13;&#10;WHEN &apos;Learning Disabilities&apos; THEN [Learning_Disabilities]&#13;&#10;WHEN &apos;Motivation Level&apos; THEN STR([Motivation_Level])&#13;&#10;WHEN &apos;Parental Education Level&apos; THEN STR([Parental_Education_Level])&#13;&#10;WHEN &apos;Parental Involvement&apos; THEN STR([Parental_Involvement])&#13;&#10;WHEN &apos;Peer Influence&apos; THEN STR([Peer_Influence])&#13;&#10;WHEN &apos;School Type&apos; THEN [School_Type]&#13;&#10;WHEN &apos;Teacher Quality&apos; THEN STR([Teacher_Quality])&#13;&#10;WHEN &apos;Risk Category&apos; THEN STR([Calculation_1388797585446313986])&#13;&#10;END' />
              <aliases>
                <alias key='&quot;High School&quot;' value='HS' />
                <alias key='&quot;Postgraduate&quot;' value='PG' />
              </aliases>
            </column>
            <column caption='MeasureSlider' datatype='integer' name='[Calculation_1205838847883902981]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Attendance&apos; THEN [Attendance]&#13;&#10;WHEN &apos;Exam Score&apos; THEN [Exam_Score]&#13;&#10;WHEN &apos;Hours Studied&apos; THEN [Hours_Studied]&#13;&#10;WHEN &apos;Physical Activity&apos; THEN [Physical_Activity]&#13;&#10;WHEN &apos;Previous Scores&apos; THEN [Previous_Scores]&#13;&#10;WHEN &apos;Sleep Hours&apos; THEN [Sleep_Hours]&#13;&#10;WHEN &apos;Tutoring Sessions&apos; THEN [Tutoring_Sessions]&#13;&#10;END' />
            </column>
            <column caption='Risk Category' datatype='string' name='[Calculation_1388797585446313986]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ([Motivation_Level] == &quot;Low&quot; OR [Attendance] &lt; 70)&#13;&#10;AND [Hours_Studied] &lt; 15&#13;&#10;THEN &quot;At Risk&quot;&#13;&#10;&#13;&#10;ELSEIF [Motivation_Level] == &quot;Medium&quot; AND [Hours_Studied] &lt; 30&#13;&#10;THEN &quot;Average&quot;&#13;&#10;&#13;&#10;ELSE &quot;High Performer&quot;&#13;&#10;END' />
            </column>
            <column caption='COUNT([MeasureSlider]) / TOTAL(COUNT([MeasureSlider])) * 100' datatype='real' name='[Calculation_5661869208548585483]' role='measure' type='quantitative' user:unnamed='Dimension Frequency'>
